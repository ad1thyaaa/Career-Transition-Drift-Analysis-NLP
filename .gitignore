# ============================================================
# .gitignore — Career Drift Trajectory Analysis
# ============================================================

# ------------------------------------------------------------
# Python bytecode & import caches
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ------------------------------------------------------------
# Distribution / packaging
# ------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ------------------------------------------------------------
# Testing & coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ------------------------------------------------------------
# Model checkpoints  (large binaries — store with DVC/LFS)
# ------------------------------------------------------------
models/
*.joblib
*.pkl
*.pickle

# ------------------------------------------------------------
# Embedding & pipeline caches
# ------------------------------------------------------------
cache/
*.npy
*.npz

# ------------------------------------------------------------
# Input data (local datasets only)
# Keep the data/ directory itself tracked (for README, etc.)
# ------------------------------------------------------------
data/*.parquet
data/*.csv
data/*.json

# ------------------------------------------------------------
# Pipeline results
# Generated artefacts:
# figures, tables, metrics, checkpoints, logs, summaries
# ------------------------------------------------------------
results/
results/figures/
results/tables/
results/metrics/
results/checkpoints/
results/logs/
results/summaries/

# ------------------------------------------------------------
# Jupyter notebooks — checkpoints
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# VSCode workspace settings
# ------------------------------------------------------------
.vscode/
*.code-workspace

# ------------------------------------------------------------
# PyCharm / JetBrains IDE
# ------------------------------------------------------------
.idea/

# ------------------------------------------------------------
# macOS / Linux / Windows OS artefacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
requirements_forthispc.txt